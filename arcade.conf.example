# ARCADE Configuration
# Copy to arcade.conf and fill in your values.
# arcade.conf is gitignored — never commit it.
# Run ./setup.sh for an interactive configuration walkthrough.

# ── Backend mode ──────────────────────────────────────────────────────────────
# oauth  — all chunks use Claude Max subscription ($0 per token)
# api    — all chunks use API_ENDPOINT / API_KEY (pay per token)
# mix    — [REASONING] chunks → oauth path, [SCAFFOLD] chunks → api path
BACKEND_MODE="oauth"

# ── OAuth provider (used when BACKEND_MODE=oauth or mix) ─────────────────────
# claude-max  — native claude auth session (recommended, no extra key needed)
# claude-pro  — Anthropic API key used on the oauth path
# custom      — arbitrary endpoint; set OAUTH_ENDPOINT below
OAUTH_PROVIDER="claude-max"
OAUTH_ENDPOINT=""

# ── API provider (used when BACKEND_MODE=api or mix) ─────────────────────────
# litellm    — local LiteLLM proxy (recommended for MooseNet / self-hosted)
# openrouter — openrouter.ai (pay per token, multi-model access)
# anthropic  — Anthropic API direct
# openai     — OpenAI API direct
# custom     — arbitrary endpoint
#
# IMPORTANT: API_ENDPOINT must NOT include a trailing /v1.
#   Claude Code appends /v1 automatically. Store the base URL only.
#   Correct:   API_ENDPOINT="http://192.168.0.215:4000"
#   Wrong:     API_ENDPOINT="http://192.168.0.215:4000/v1"
API_PROVIDER="litellm"
API_ENDPOINT="http://your-litellm-host:4000"
API_KEY="your-api-key-here"
API_MODEL=""   # model name passed to --model; leave blank for per-mode defaults

# ── Queue path for mix-mode chunk detection ───────────────────────────────────
# Path to the active project's queue.md. start-arcade.sh reads the next pending
# chunk label ([REASONING] or [SCAFFOLD]) to select the backend in mix mode.
# masterarcade.sh sets this at runtime; override here for manual invocations only.
QUEUE_PATH=""

# ── Legacy / direct override ──────────────────────────────────────────────────
# start-arcade.sh derives ANTHROPIC_BASE_URL and ANTHROPIC_API_KEY from the
# provider config above at runtime. Set these manually only to bypass routing.
ANTHROPIC_BASE_URL=""
ANTHROPIC_API_KEY=""

# ── OpenRouter (for balance checks and direct OpenRouter routing) ─────────────
# Leave blank if not using OpenRouter.
OPENROUTER_API_KEY=""

# ── LiteLLM spend logging (for cost= field in run-log) ───────────────────────
# Leave blank if not using LiteLLM, or if LiteLLM has no master key.
LITELLM_MASTER_KEY=""
LITELLM_URL="http://your-litellm-host:4000"

# ── GitHub (for state repo management) ───────────────────────────────────────
# ARCADE pushes run-log.md and queue.md to a GitHub state repo after each chunk.
# Leave blank for local-only operation.
# Token requires: classic personal access token, repo scope.
GITHUB_URL="https://api.github.com"
GITHUB_TOKEN=""
GITHUB_ORG="your-username-or-org"

# ── State storage root ────────────────────────────────────────────────────────
# Local directory or network mount. Must be writable by the user running ARCADE.
ARCADE_STATE_ROOT="${HOME}/.arcade/projects"

# ── Cost limits ───────────────────────────────────────────────────────────────
ARCADE_MAX_BUDGET_USD="5.00"
ARCADE_MIN_BALANCE_USD="1.00"

# ── Loop settings ─────────────────────────────────────────────────────────────
MAX_ITERATIONS="3"

# ── Calx (optional) ──────────────────────────────────────────────────────────
# Path to the Python venv containing getcalx. Leave blank to disable Calx.
# Install: python3 -m venv ~/.calx-venv && ~/.calx-venv/bin/pip install getcalx
# CALX_VENV="${HOME}/.calx-venv"
CALX_VENV=""
